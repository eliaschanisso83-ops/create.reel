{
  "name": "image2video-lite",
  "private": true,
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "install:all": "npm install --workspace=frontend && npm install --workspace=backend",
    "dev": "npm install --workspace=frontend && npm install --workspace=backend && npm run dev:backend & npm run dev:frontend",
    "dev:backend": "npm --workspace=backend start",
    "dev:frontend": "npm --workspace=frontend run dev",
    "start": "npm --workspace=backend start",
    "build": "npm --workspace=frontend build"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
